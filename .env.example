# =============================================================================
# Trackarr Environment Configuration
# =============================================================================
# This file works for both development and production.
# Copy to .env and adjust values as needed.
#
# DEVELOPMENT: Use defaults as-is with `docker compose up -d`
# PRODUCTION:  Use docker-compose.prod.yml and generate all secrets below

# -----------------------------------------------------------------------------
# Environment Mode
# -----------------------------------------------------------------------------
NODE_ENV=development

# -----------------------------------------------------------------------------
# Container images
# -----------------------------------------------------------------------------
# The compose files pull pre-built images from GitHub Container Registry by
# default. Pin a specific release (e.g. IMAGE_TAG=0.11.0) or stay on `latest`
# to follow the rolling tag.
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Domain Configuration (Production only)
# -----------------------------------------------------------------------------
# DOMAIN=your-tracker.com
# TRACKER_DOMAIN=tracker.your-tracker.com
# ACME_EMAIL=admin@your-tracker.com

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Development (SSL disabled)
DATABASE_URL=postgres://tracker:tracker@localhost:5432/trackarr

# Production (SSL enforced - sslmode=require automatically added in nuxt.config.ts)
# DATABASE_URL=postgres://tracker:STRONG_PASSWORD@pgbouncer:6432/trackarr

# Production database settings
DB_USER=tracker
# ⚠️  PRODUCTION: Generate with: openssl rand -base64 32
DB_PASSWORD=tracker
DB_NAME=trackarr
DB_PORT=5432

# Database connection pool
DB_POOL_MAX=20

# SSL/TLS for database connections
# Development: SSL disabled for local testing
# Production: SSL automatically enforced (see documentation/ssl-setup.md)
# Generate certificates with: ./scripts/generate-ssl-certs.sh

# Debug mode (never enable in production)
DB_DEBUG=false

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# Redis authentication (REQUIRED for production)
REDIS_PASSWORD=

# Redis key prefix (namespace isolation)
REDIS_KEY_PREFIX=ot:

# Redis port (for docker-compose)
REDIS_PORT=6379

# SSL/TLS for Redis connections
REDIS_TLS=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
# REDIS_TLS_CA=/path/to/ca-certificate.crt

# -----------------------------------------------------------------------------
# Tracker Ports
# -----------------------------------------------------------------------------
TRACKER_PORT=8000
TRACKER_HTTP_PORT=8080
TRACKER_UDP_PORT=8081
TRACKER_WS_PORT=8082

# Debug mode for verbose tracker logging (logs raw announce params)
TRACKER_DEBUG=false

# Tracker announce URLs (displayed in admin dashboard for .torrent files)
# Read at RUNTIME by Nuxt — the NUXT_PUBLIC_ prefix is required so the same Docker
# image can be reused by anyone with their own domain (no rebuild needed).
# ⚠️  PRODUCTION: Configure these with your actual domain
NUXT_PUBLIC_TRACKER_HTTP_URL=https://tracker.your-domain.com/announce
NUXT_PUBLIC_TRACKER_UDP_URL=udp://tracker.your-domain.com:8081/announce
NUXT_PUBLIC_TRACKER_WS_URL=wss://tracker.your-domain.com/ws

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------

# Session encryption (REQUIRED for production - generate with: openssl rand -hex 32)
NUXT_SESSION_SECRET=

# Admin API key (REQUIRED for production - generate with: openssl rand -hex 32)
ADMIN_API_KEY=

# IP hashing secret (REQUIRED — app refuses to start without it)
# Generate with: openssl rand -hex 32
IP_HASH_SECRET=

# Trust upstream proxy headers (X-Forwarded-For / X-Real-IP) for the client IP.
# Set to "true" ONLY when the app is behind a reverse proxy you control (Caddy).
# Leaving it off when exposed directly prevents rate-limit / IP-blacklist bypass via header spoofing.
TRUST_PROXY=false

# Trust the CF-Connecting-IP header (api + tracker). Keep "false" UNLESS the
# stack is genuinely fronted by Cloudflare AND ingress is locked to
# Cloudflare's published IP ranges. The bundled Caddyfile does not set this
# header and strips it, so on a non-Cloudflare edge it is attacker-supplied:
# trusting it would let a client forge its IP to bypass bans/rate limits or
# frame a victim's IP into the blacklist.
TRUST_CF_CONNECTING_IP=false

# Hosts allowed to bypass the SSRF guard's private/loopback block (api).
# Comma-separated EXACT hostnames. Needed only to FEDERATE with a peer
# reachable over a private network (LAN, VPN like Tailscale/WireGuard, or a
# docker service name) — its S2S URL resolves to a private IP the guard would
# otherwise refuse. Empty = unchanged SSRF protection. List only trusted peer
# hosts, e.g. SAFE_FETCH_ALLOW_HOSTS=peer-b.internal,10.0.0.5
SAFE_FETCH_ALLOW_HOSTS=

# -----------------------------------------------------------------------------
# Media metadata lookup (opt-in)
# -----------------------------------------------------------------------------
# When set, the API exposes /api/metadata/lookup which fetches poster,
# overview, genres, etc. from TMDb for any IMDb / TMDb / TVDB id stored
# on a torrent. Without this key the UI silently hides the metadata
# card and the upload-modal "Lookup" button.
#
# Two credential shapes are accepted (the backend auto-detects which
# you supplied — JWTs always contain a "."):
#   1. v3 API key            — 32-char hex, e.g. 1234567890abcdef…
#   2. v4 Read-Only Access   — JWT-shaped token, e.g. eyJhbGciOiJIUzI1NiJ9…
#      Token (Bearer)
# Both come from https://www.themoviedb.org/settings/api
# TMDB_API_KEY=

# -----------------------------------------------------------------------------
# Prometheus Metrics (opt-in)
# -----------------------------------------------------------------------------
# When enabled, the API process binds a separate HTTP server exposing
# Prometheus-format metrics. Keep this port firewalled from the public
# internet — it's intended for your monitoring network only.
#
# METRICS_ENABLED          true to start the scrape endpoint (default: off)
# METRICS_PORT             port to bind (default: 9090)
# METRICS_HOST             interface to bind (default: 0.0.0.0)
# METRICS_PATH             scrape path (default: /metrics)
# METRICS_AUTH_TOKEN       if set, scrapes must send `Authorization: Bearer <token>`
# METRICS_PEER_CACHE_MS    cache TTL for the expensive Redis SCAN over peers (default: 30000)
METRICS_ENABLED=false
METRICS_PORT=9090
# METRICS_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Quick Start
# -----------------------------------------------------------------------------
#
# DEVELOPMENT:
#   cp .env.example .env
#   docker compose up -d
#   npm run dev
#
# PRODUCTION:
#   cp .env.example .env
#   # Generate all secrets:
#   echo "NODE_ENV=production" >> .env
#   echo "NUXT_SESSION_SECRET=$(openssl rand -hex 32)" >> .env
#   echo "ADMIN_API_KEY=$(openssl rand -hex 32)" >> .env
#   echo "IP_HASH_SECRET=$(openssl rand -hex 32)" >> .env
#   echo "DB_PASSWORD=$(openssl rand -base64 24)" >> .env
#   echo "REDIS_PASSWORD=$(openssl rand -base64 24)" >> .env
#   # Configure domains
#   echo "DOMAIN=your-tracker.com" >> .env
#   # Start
#   docker compose -f docker-compose.prod.yml up -d

