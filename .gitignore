# =============================================================================
# Build outputs
# =============================================================================
.output
.nuxt
.nitro
.cache
.data
dist
*.tsbuildinfo

# Dev-only volumes used by scripts/tests
.dev-test
.dev-downloads
.vitepress/cache

# =============================================================================
# Dependencies
# =============================================================================
node_modules

# pnpm is the canonical package manager for the monorepo. Ignore stray lockfiles
# for npm/yarn at the repo root. (doc/ is a separate VitePress sub-project that
# uses its own package-lock.json — only the root one is ignored.)
/package-lock.json
yarn.lock
.pnpm-store/

# =============================================================================
# Logs
# =============================================================================
logs
*.log
pnpm-debug.log*
npm-debug.log*

# =============================================================================
# Tests
# =============================================================================
coverage/

# =============================================================================
# Environment & secrets (never commit)
# =============================================================================
.env
.env.*
!.env.example

CREDENTIALS.txt
secrets/
docker/pgbouncer/userlist.txt

# SSL/TLS certificates
certs/
*.key
*.crt
*.csr
*.pem

