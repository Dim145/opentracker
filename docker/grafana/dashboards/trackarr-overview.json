{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Trackarr metrics scrape target",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "description": "Trackarr operator dashboard — covers users, torrents, swarm, moderation, anti-cheat, bonus economy, bounty board, social graph, and cron health. Scrape interval recommended: 15s.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "id": 100,
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Users",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "targets": [
        { "expr": "trackarr_users_total", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Torrents",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "trackarr_torrents_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active peers",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "trackarr_peers_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total content",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "targets": [{ "expr": "trackarr_torrents_bytes_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] },
          "unit": "bytes"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "DB size",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "trackarr_database_size_bytes", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "bytes"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Redis memory",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "trackarr_redis_memory_bytes", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "unit": "bytes"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },

    {
      "type": "row",
      "id": 200,
      "title": "Swarm",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Peers / seeders / leechers",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        { "expr": "trackarr_peers_total", "legendFormat": "peers", "refId": "A" },
        { "expr": "trackarr_seeders_total", "legendFormat": "seeders", "refId": "B" },
        { "expr": "trackarr_leechers_total", "legendFormat": "leechers", "refId": "C" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "lineWidth": 2 },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull", "max"] } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Torrents by moderation status",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        { "expr": "trackarr_torrents_by_status", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 30, "stacking": { "mode": "normal" } },
          "unit": "short"
        }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"] } }
    },

    {
      "type": "row",
      "id": 300,
      "title": "Moderation",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 20,
      "type": "stat",
      "title": "Moderation queue depth",
      "description": "Pending + changes_requested. The work waiting on staff.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "sum(trackarr_torrents_by_status{status=~\"pending|changes_requested\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 21,
      "type": "stat",
      "title": "Pending reports",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 15 },
      "targets": [{ "expr": "trackarr_reports_pending_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 22,
      "type": "stat",
      "title": "Active HnR",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 15 },
      "targets": [{ "expr": "trackarr_hnr_active_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }, "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 23,
      "type": "stat",
      "title": "Banned IPs",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 15 },
      "targets": [{ "expr": "trackarr_banned_ips_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] }, "unit": "short" }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "Moderation messages by kind",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        { "expr": "trackarr_torrent_moderation_messages_total", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }, "unit": "short" }
      },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 25,
      "type": "piechart",
      "title": "Reports / decisions distribution",
      "description": "Currently shows pending reports — combine with a Loki dashboard for resolved/dismissed history.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        { "expr": "trackarr_reports_pending_total", "legendFormat": "pending", "refId": "A" }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "right" } }
    },

    {
      "type": "row",
      "id": 400,
      "title": "Anti-cheat",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 30,
      "type": "stat",
      "title": "Anti-cheat queue depth",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 29 },
      "targets": [{ "expr": "trackarr_anticheat_flags_unreviewed_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "id": 31,
      "type": "piechart",
      "title": "Anti-cheat flags by kind",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 29 },
      "targets": [
        { "expr": "trackarr_anticheat_flags_by_kind", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Anti-cheat fresh flags over time",
      "description": "Rate of new flags per kind (delta of a gauge — works when the gauge is monotonic over the window).",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 29 },
      "targets": [
        { "expr": "max_over_time(trackarr_anticheat_flags_by_kind[5m]) - min_over_time(trackarr_anticheat_flags_by_kind[5m])", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 }, "unit": "short" } },
      "options": { "legend": { "displayMode": "list" } }
    },

    {
      "type": "row",
      "id": 500,
      "title": "Users & 2FA",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 40,
      "type": "piechart",
      "title": "Users by role",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 38 },
      "targets": [
        { "expr": "trackarr_users_by_role", "legendFormat": "{{role}}", "refId": "A" }
      ],
      "options": { "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] } }
    },
    {
      "id": 41,
      "type": "gauge",
      "title": "TOTP adoption",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 4, "x": 8, "y": 38 },
      "targets": [
        { "expr": "100 * trackarr_users_totp_enabled_total / clamp_min(trackarr_users_total, 1)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 25 },
              { "color": "green", "value": 60 }
            ]
          }
        }
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 42,
      "type": "gauge",
      "title": "Passkey adoption",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 4, "x": 12, "y": 38 },
      "targets": [
        { "expr": "100 * trackarr_users_with_passkey_total / clamp_min(trackarr_users_total, 1)", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0, "max": 100, "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 15 },
              { "color": "green", "value": 40 }
            ]
          }
        }
      },
      "options": { "showThresholdLabels": false, "showThresholdMarkers": true }
    },
    {
      "id": 43,
      "type": "stat",
      "title": "Banned users (active)",
      "description": "is_banned = true. Includes both permanent and timed bans.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 38 },
      "targets": [{ "expr": "trackarr_users_banned_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "red" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 44,
      "type": "stat",
      "title": "Timed bans (expiring)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 38 },
      "targets": [{ "expr": "trackarr_users_banned_expiring_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 45,
      "type": "stat",
      "title": "Ban expiry cron backlog",
      "description": "Sustained values > 0 mean the 5-min ban-expiry cron is stuck. Should hover near 0 in steady state.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 42 },
      "targets": [{ "expr": "trackarr_users_banned_expired_pending_total", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 46,
      "type": "stat",
      "title": "Trusted devices",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 42 },
      "targets": [{ "expr": "trackarr_trusted_devices_active_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },

    {
      "type": "row",
      "id": 600,
      "title": "Bonus economy",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 50,
      "type": "stat",
      "title": "Bonus event active?",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 47 },
      "targets": [{ "expr": "trackarr_bonus_event_active", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Idle", "color": "blue" }, "1": { "text": "LIVE", "color": "red" } } }
          ],
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "textMode": "value_and_name" }
    },
    {
      "id": 51,
      "type": "timeseries",
      "title": "Active multipliers (1.0 = identity)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 12, "x": 4, "y": 47 },
      "targets": [
        { "expr": "trackarr_bonus_active_download_multiplier", "legendFormat": "download", "refId": "A" },
        { "expr": "trackarr_bonus_active_upload_multiplier", "legendFormat": "upload", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "min": 0, "max": 3, "custom": { "drawStyle": "line", "fillOpacity": 15, "lineWidth": 2 } } },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 52,
      "type": "stat",
      "title": "Shop purchases (lifetime)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 47 },
      "targets": [{ "expr": "trackarr_shop_purchases_total", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 53,
      "type": "stat",
      "title": "Shop items (enabled)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 47 },
      "targets": [{ "expr": "trackarr_shop_items_by_status{status=\"enabled\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 54,
      "type": "stat",
      "title": "Event ends in",
      "description": "Seconds until the active bonus event ends. Shows '∅' when no event is running.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 52 },
      "targets": [{ "expr": "trackarr_bonus_event_active_ends_at_seconds - time()", "refId": "A" }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "noValue": "∅",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }, { "color": "red", "value": -1 }] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },

    {
      "type": "row",
      "id": 700,
      "title": "Bounty board (upload requests)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 60,
      "type": "stat",
      "title": "Open requests",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 0, "y": 58 },
      "targets": [
        { "expr": "trackarr_upload_requests_by_status{status=\"requested\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 61,
      "type": "stat",
      "title": "Filled (awaiting decision)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 5, "w": 4, "x": 4, "y": 58 },
      "targets": [
        { "expr": "trackarr_upload_requests_by_status{status=\"filled\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "orange" } } },
