# Trackarr production Caddyfile
# Routes:
#   - your-domain.com/api/*    → api container
#   - your-domain.com/announce → tracker container (announce on main domain)
#   - your-domain.com/*        → web container (Nuxt SSR)
#   - tracker.your-domain.com/announce → tracker container (announce on subdomain)

{
	email {$ACME_EMAIL:admin@example.com}
}

# Strip client-suppliable IP-trust headers before proxying upstream.
# We overwrite X-Real-IP / X-Forwarded-For with the real peer in every
# block below, but CF-Connecting-IP / True-Client-IP are NOT set here and
# would otherwise pass through verbatim. The api (getClientIP) and tracker
# (clientIP) read CF-Connecting-IP first, so a client sending a forged
# value could spoof its effective IP — bypassing IP bans + rate limits and
# framing a victim's IP into the DDoS blacklist (finding H2). Imported into
# every reverse_proxy block. Re-add these headers ONLY if the stack is
# genuinely fronted by Cloudflare AND ingress is restricted to Cloudflare's
# published IP ranges (and set TRUST_CF_CONNECTING_IP=true on api+tracker).
(strip_spoofable_ip_headers) {
	header_up -CF-Connecting-IP
	header_up -True-Client-IP
}

# -----------------------------------------------------------------------------
# Main app: web frontend + api + tracker on the same hostname
# -----------------------------------------------------------------------------
{$DOMAIN:localhost} {
	header {
		# Clickjacking: SAMEORIGIN keeps the auth/upload flows
		# embeddable from the same domain (useful for OAuth-style
		# popups in future) but blocks any external iframe wrapping
		# admin pages.
		X-Frame-Options "SAMEORIGIN"
		X-Content-Type-Options "nosniff"
		# X-XSS-Protection is removed: deprecated by browsers and
		# can introduce its own bugs. CSP below replaces it.
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()"
		# CSP — locks scripts/frames to first-party. `unsafe-inline`
		# is currently required by the Nuxt FOUC theme script in
		# app.vue (constant string, not user-controlled, so the XSS
		# risk is nil); when that script moves to a nonce-scoped
		# external file we can drop the keyword.
		# fonts.googleapis.com (CSS) + fonts.gstatic.com (font binaries)
		# are explicitly allow-listed because main.css imports the Inter
		# and JetBrains Mono families from there. If you bundle fonts
		# locally instead, the two extra hosts can be dropped.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https:; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'"
		-Server
	}

	encode gzip zstd

	# Tracker announce on the main domain (what BitTorrent clients hit when
	# the .torrent file's `announce` is your-domain.com/announce).
	handle /announce* {
		reverse_proxy tracker:8080 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			import strip_spoofable_ip_headers
		}
	}

	# All API routes (including /api/uploads/*, /api/health, /api/torrents/...).
	handle /api/* {
		reverse_proxy api:4000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			import strip_spoofable_ip_headers
		}
	}

	# Public uploads served by the API.
	handle /uploads/* {
		reverse_proxy api:4000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			import strip_spoofable_ip_headers
		}
	}

	# Everything else goes to the Nuxt web container (SSR pages + assets).
	handle {
		reverse_proxy web:3000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-For {remote_host}
			header_up X-Forwarded-Proto {scheme}
			import strip_spoofable_ip_headers
		}
	}

	# Drop the `passkey` query param from access logs before they hit
	# disk. The tracker requires it in the URL by BitTorrent protocol,
	# so we can't strip it from the request itself, but we can prevent
	# it from being persisted in the log file (which is otherwise a
	# textbook log-leak vector for credential exfiltration).
	log {
		output file /var/log/caddy/access.log {
			roll_size 100mb
			roll_keep 10
			roll_keep_for 720h
		}
		format filter {
			wrap json
			fields {
				uri query {
					delete passkey
				}
			}
		}
	}
}

# -----------------------------------------------------------------------------
# Tracker subdomain: dedicated host so .torrent announce URLs can use a clean
# `tracker.your-domain.com/announce` URL.
# -----------------------------------------------------------------------------
{$TRACKER_DOMAIN:tracker.localhost} {
	header {
		X-Content-Type-Options "nosniff"
		-Server
	}

	reverse_proxy tracker:8080 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-For {remote_host}
		import strip_spoofable_ip_headers
	}

	# Same passkey scrub as on the main domain — every request to this
	# subdomain is an announce, so every line otherwise carries a
	# passkey in the URL.
	log {
		output file /var/log/caddy/tracker.log {
			roll_size 100mb
			roll_keep 5
		}
		format filter {
			wrap json
			fields {
				uri query {
					delete passkey
				}
			}
		}
	}
}
